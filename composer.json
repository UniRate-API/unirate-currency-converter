{
    "name": "unirate-api/unirate-currency-converter",
    "description": "Official WordPress plugin for UniRate API — live currency conversion in posts, pages, and blocks.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "keywords": ["unirate", "currency", "exchange-rates", "wordpress", "gutenberg", "widget"],
    "homepage": "https://github.com/UniRate-API/unirate-currency-converter",
    "authors": [
        {
            "name": "Unirate Team",
            "homepage": "https://unirateapi.com"
        }
    ],
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "10up/wp_mock": "^1.0"
    },
    "autoload-dev": {
        "classmap": [
            "tests/"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable"
}
